"LN_ChannelTabNoPrivilegeToEdit_943153" = "Nie masz uprawnień do edycji zakładki.";
"LN_New_Voiceprint_Needed_631613" = "Potrzebny nowy spektogram";
"LN_Voiceprint_Failed_631613" = "Coś poszło nie tak. Spróbuj zredukować zakłócenia dźwięku lub hałas w tle, upewnij się, że mikrofon nie jest wyciszony oraz ma silny sygnał wejściowy, i ponownie nagrywaj swój głos przez co najmniej 30 sekund. Jeśli problem będzie się powtarzał, uruchom ponownie mikrofon i spróbuj jeszcze raz.";
"LN_Record_Voiceprint_Failed_631613" = "Coś poszło nie tak. Spróbuj zredukować zakłócenia dźwięku lub hałas w tle i ponownie nagrywaj spektogram przez co najmniej 30 sekund.";
"LN_Voice_Print_Record_Success_Info_631613" = "Pomyślnie nagrano spektogram. Ta sygnatura będzie używana domyślnie podczas optymalizacji danych głosowych. Przypominamy, że ta sygnatura dźwiękowa może zostać usunięta przez Ciebie w dowolnym momencie.";
"LN_Audio_Signature_Failed_631613" = "Nie udało się nagrać podpisu audio";
