"LN_Account_Owner_267228" = "Chủ sở hữu tài khoản";
"LN_Meeting_Record_Consent_Disclaimer_524842" = "%@ có thể xem bản ghi này nếu bản ghi được lưu trữ trên đám mây. Người tham gia được cấp quyền có thể ghi lại và chia sẻ bản ghi của họ trên các ứng dụng và với người khác.\n\nNgười tham gia được cấp các quyền liên quan cũng có thể lưu và chia sẻ phiên âm cuộc họp.";
"LN_Webinar_Record_Consent_Content_267228" = "Khi ở lại hội thảo trực tuyến này, bạn đồng ý được ghi lại.";
"LN_Meeting_Record_Consent_Content_267228" = "Khi ở lại cuộc họp này, bạn đồng ý được ghi lại.";
"LN_Meeting_Record_Consent_Disclaimer_267228" = "%@ cũng có thể xem bản ghi này nếu nó được lưu trữ trên đám mây. Bất kỳ người tham gia nào được cấp quyền đều có thể (1) ghi vào thiết bị cục bộ của họ hoặc (2) mời một ứng dụng ghi lại cho họ. Những người này có thể chia sẻ bản ghi với các ứng dụng và người khác.";
"LN_Meeting_Livestream_Consent_Title_267228" = "Cuộc họp này đang được phát trực tiếp";
"LN_Meeting_Livestream_Consent_Content_267228" = "Khi ở lại cuộc họp này, bạn đồng ý được phát trực tiếp.\n\nBất kỳ ai có quyền truy cập vào buổi phát trực tiếp đều có thể xem hoặc chia sẻ với những người khác.";
"LN_Host_Allow_Attendee_To_Talk_Title_267228" = "Người chủ trì muốn bạn nói";
"LN_Host_Allow_Attendee_To_Talk_Content_579007" = "Nếu bạn chọn bỏ tắt tiếng, những người khác trong hội thảo trực tuyến sẽ có thể nghe thấy bạn. Nếu người chủ trì hoặc những người tham gia chính quyết định ghi lại, phát trực tiếp hoặc lưu trữ hội thảo trực tuyến sau khi bạn bỏ tắt tiếng, sẽ bao gồm cả giọng nói của bạn. Chọn ghi lại thông minh bằng công nghệ AI, có thể bao gồm cả mô hình của bên thứ ba để chia sẻ bản ghi. Zoom không sử dụng bất kỳ nội dung nào dưới dạng âm thanh, video, cuộc trò chuyện, chia sẻ màn hình, tệp đính kèm hoặc nội dung tương tự như thông tin truyền thông khác (chẳng hạn như kết quả bình chọn, bảng trắng và phản ứng) để đào tạo các mô hình AI của Zoom hoặc bên thứ ba.\n\nNgười tham gia có các quyền liên quan cũng có thể lưu và chia sẻ bản phiên âm hội thảo trực tuyến.";
"LN_Host_Allow_Attendee_To_Talk_Content_539636" = "Nếu bạn chọn bỏ tắt tiếng, những người khác trong hội thảo trực tuyến sẽ có thể nghe thấy bạn. Nếu người chủ trì hoặc những người tham gia chính quyết định ghi lại, phát trực tiếp hoặc lưu trữ hội thảo trực tuyến sau khi bạn bật tiếng, sẽ bao gồm cả giọng nói của bạn. Bản ghi có thể được chia sẻ bằng Ghi lại thông minh để phân tích và cải tiến sản phẩm của Zoom nếu đã được lưu trữ trên đám mây.\n\nNgười tham gia có các quyền liên quan cũng có thể lưu và chia sẻ bản phiên âm hội thảo trực tuyến.";
"LN_Host_Allow_Attendee_To_Talk_Content_267228" = "Nếu bạn chọn bỏ tắt tiếng, những người khác trong hội thảo trực tuyến sẽ có thể nghe thấy bạn. Nếu người chủ trì hoặc những người tham gia chính quyết định ghi lại, phát trực tiếp hoặc lưu trữ hội thảo trực tuyến sau khi bạn bỏ tắt tiếng, sẽ bao gồm cả giọng nói của bạn. Bản ghi có thể được chia sẻ với tính năng Ghi lại thông minh để phân tích và cải tiến sản phẩm của Zoom nếu bản ghi đó được lưu trữ trên đám mây.\n\nNgười tham gia được cấp các quyền liên quan cũng có thể lưu và chia sẻ phiên âm cuộc họp.";
